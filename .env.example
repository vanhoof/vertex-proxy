# vertex-proxy environment configuration
# Copy to .env and fill in your values.

# Required: your GCP project ID
VERTEX_PROXY_PROJECT_ID=your-gcp-project-id

# Regions (defaults shown)
VERTEX_PROXY_ANTHROPIC_REGION=global
VERTEX_PROXY_GEMINI_REGION=us-central1
VERTEX_PROXY_EMBEDDING_REGION=global
VERTEX_PROXY_MAAS_REGION=us-central1

# Logging
VERTEX_PROXY_LOG_LEVEL=info

# Metrics (Prometheus format at /metrics)
VERTEX_PROXY_METRICS_ENABLED=false

# Optional: path to your gcloud ADC file (default shown)
# GOOGLE_ADC_PATH=~/.config/gcloud/application_default_credentials.json
