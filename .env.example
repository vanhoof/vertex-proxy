# vertex-proxy environment configuration
# Copy to .env and fill in your values.

# Required: your GCP project ID
VERTEX_PROXY_PROJECT_ID=your-gcp-project-id

# Regions (defaults shown)
VERTEX_PROXY_ANTHROPIC_REGION=global
VERTEX_PROXY_GEMINI_REGION=us-central1
VERTEX_PROXY_EMBEDDING_REGION=global
VERTEX_PROXY_MAAS_REGION=us-central1

# Logging
VERTEX_PROXY_LOG_LEVEL=info

# Metrics (Prometheus format at /metrics)
VERTEX_PROXY_METRICS_ENABLED=false

# Optional: bearer token to protect the proxy on a LAN (default: no auth)
# VERTEX_PROXY_API_KEY=your-secret-token

# Auth: path to your GCP credentials file. Works with either:
#   - Application Default Credentials (gcloud auth application-default login)
#   - Service account JSON key (download from GCP Console > IAM > Service Accounts)
# Default: ~/.config/gcloud/application_default_credentials.json
# GOOGLE_ADC_PATH=/path/to/your/credentials.json

# Host port for run.sh (docker-compose.yml has its own port mapping)
# VERTEX_PROXY_HOST_PORT=8788
